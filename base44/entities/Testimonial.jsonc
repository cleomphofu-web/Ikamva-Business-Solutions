{
  "name": "Testimonial",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "quote": {
      "type": "string"
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "approved": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "name",
    "quote",
    "rating"
  ]
}